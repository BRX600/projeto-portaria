<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h2><i class="bi bi-door-open"></i> Registro de Entrada / Saída</h2>
  <a href="/pessoas/nova" class="btn btn-outline-primary btn-sm">
    <i class="bi bi-plus"></i> Nova Pessoa
  </a>
</div>

<% if (mensagem) { %>
  <div class="alert alert-success alert-dismissible fade show">
    <i class="bi bi-check-circle"></i> <%= mensagem %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>

<% if (erro) { %>
  <div class="alert alert-danger alert-dismissible fade show">
    <i class="bi bi-exclamation-triangle"></i> <%= erro %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>

<% if (pessoas.length === 0) { %>
  <div class="alert alert-info">
    Nenhuma pessoa cadastrada.
    <a href="/pessoas/nova">Cadastre a primeira aqui.</a>
  </div>
<% } else { %>
  <table class="table table-hover align-middle">
    <thead class="table-dark">
      <tr>
        <th>Nome</th>
        <th>Documento</th>
        <th>Status</th>
        <th>Entrada em</th>
        <th>Ação</th>
      </tr>
    </thead>
    <tbody>
      <% pessoas.forEach((p) => { %>
      <tr class="<%= p.dentro ? 'table-warning' : '' %>">
        <td><strong><%= p.nome %></strong></td>
        <td><%= p.documento %></td>
        <td>
          <% if (p.dentro) { %>
            <span class="badge bg-warning text-dark"><i class="bi bi-house-fill"></i> Dentro</span>
          <% } else { %>
            <span class="badge bg-secondary"><i class="bi bi-house-dash"></i> Fora</span>
          <% } %>
        </td>
        <td>
          <% if (p.entradaEm) { %>
            <%= new Date(p.entradaEm).toLocaleString('pt-BR') %>
          <% } else { %>
            —
          <% } %>
        </td>
        <td>
          <% if (p.dentro) { %>
            <form action="/acessos/saida/<%= p.acessoId %>" method="POST" class="d-inline">
              <button type="submit" class="btn btn-danger btn-sm"
                      onclick="return confirm('Registrar saída de <%= p.nome %>?')">
                <i class="bi bi-box-arrow-right"></i> Registrar Saída
              </button>
            </form>
          <% } else { %>
            <form action="/acessos/entrada/<%= p.id %>" method="POST" class="d-inline">
              <button type="submit" class="btn btn-success btn-sm">
                <i class="bi bi-box-arrow-in-right"></i> Registrar Entrada
              </button>
            </form>
          <% } %>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
<% } %>

<%- include('../partials/footer') %>
