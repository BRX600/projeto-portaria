<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h2><i class="bi bi-clock-history"></i> Histórico de Acessos</h2>
  <a href="/acessos" class="btn btn-outline-secondary btn-sm">
    <i class="bi bi-arrow-left"></i> Voltar
  </a>
</div>

<!-- Filtro por pessoa -->
<form action="/acessos/historico" method="GET" class="row g-2 mb-4">
  <div class="col-md-4">
    <select name="pessoa_id" class="form-select">
      <option value="">— Todas as pessoas —</option>
      <% pessoas.forEach((p) => { %>
        <option value="<%= p.id %>" <%= String(pessoaIdFiltro) === String(p.id) ? 'selected' : '' %>>
          <%= p.nome %> (<%= p.documento %>)
        </option>
      <% }) %>
    </select>
  </div>
  <div class="col-auto">
    <button type="submit" class="btn btn-primary">
      <i class="bi bi-funnel"></i> Filtrar
    </button>
    <a href="/acessos/historico" class="btn btn-outline-secondary">Limpar</a>
  </div>
</form>

<% if (acessos.length === 0) { %>
  <div class="alert alert-info">Nenhum registro encontrado.</div>
<% } else { %>
  <table class="table table-striped table-hover align-middle">
    <thead class="table-dark">
      <tr>
        <th>#</th>
        <th>Nome</th>
        <th>Documento</th>
        <th>Entrada</th>
        <th>Saída</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>
      <% acessos.forEach((a, i) => { %>
      <tr>
        <td><%= i + 1 %></td>
        <td><%= a.nome %></td>
        <td><%= a.documento %></td>
        <td><%= new Date(a.entrada).toLocaleString('pt-BR') %></td>
        <td>
          <% if (a.saida) { %>
            <%= new Date(a.saida).toLocaleString('pt-BR') %>
          <% } else { %>
            <em class="text-muted">Ainda dentro</em>
          <% } %>
        </td>
        <td>
          <% if (a.status === 'dentro') { %>
            <span class="badge bg-warning text-dark">Dentro</span>
          <% } else { %>
            <span class="badge bg-success">Saiu</span>
          <% } %>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
<% } %>

<%- include('../partials/footer') %>
