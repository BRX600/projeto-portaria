<%- include('../partials/header') %>

<div class="row justify-content-center">
  <div class="col-md-6">
    <h2 class="mb-4"><i class="bi bi-person-plus"></i> Cadastrar Pessoa</h2>

    <% if (erro) { %>
      <div class="alert alert-danger"><i class="bi bi-exclamation-triangle"></i> <%= erro %></div>
    <% } %>

    <form action="/pessoas" method="POST" class="card p-4 shadow-sm">
      <div class="mb-3">
        <label for="nome" class="form-label fw-semibold">Nome completo</label>
        <input type="text" id="nome" name="nome" class="form-control"
               placeholder="Ex: João da Silva" required />
      </div>

      <div class="mb-3">
        <label for="documento" class="form-label fw-semibold">Documento (CPF ou RG)</label>
        <input type="text" id="documento" name="documento" class="form-control"
               placeholder="Ex: 123.456.789-00" required />
        <div class="form-text">Digite o CPF ou RG sem formatação especial.</div>
      </div>

      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">
          <i class="bi bi-check-circle"></i> Cadastrar
        </button>
        <a href="/pessoas" class="btn btn-secondary">
          <i class="bi bi-arrow-left"></i> Voltar
        </a>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/footer') %>
